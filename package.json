{
  "name": "NotesApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "android-clean": "cd android && ./gradlew clean",
    "android-build": "cd android && ./gradlew assembleRelease",
    "android-install": "cd android && ./gradlew installRelease",
    "android:prod": "react-native run-android --mode=release",
    "android:release": "react-native build-android --mode=release",
    "ios:prod": "react-native run-ios --configuration Release",
    "ios:release": "react-native build-ios --configuration Release",
    "build:all": "npm run android-build && npm run ios:release",
    "build:ios": "react-native bundle --reset-cache --platform='ios' --dev=false --entry-file='index.js' --bundle-output='ios/main.jsbundle'",
    "build:android": "react-native bundle --reset-cache --platform='android' --dev=false --entry-file='index.js' --bundle-output='android/app/src/main/assets/index.android.bundle'",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.9",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.15.1",
    "dayjs": "^1.11.20",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-blob-util": "^0.24.9",
    "react-native-calendars": "^1.1314.0",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "^2.31.0",
    "react-native-keychain": "^10.0.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-share": "^12.3.1",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-svg": "^15.15.4",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-uuid": "^2.0.4",
    "react-redux": "^9.2.0",
    "timezone": "^1.0.23",
    "utc": "^0.1.0",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "^0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
